# .env.example - Copy to .env and fill in actual values

# ============================================================================
# BLOCKCHAIN & WEB3 CONFIGURATION
# ============================================================================

# Web3 Provider URL (Infura, Alchemy, or custom RPC)
# Examples:
# - Mainnet: https://mainnet.infura.io/v3/YOUR_PROJECT_ID
# - Polygon: https://polygon-rpc.com/
# - Sepolia Testnet: https://sepolia.infura.io/v3/YOUR_PROJECT_ID
WEB3_PROVIDER_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Governance Smart Contract Address (deployed on blockchain)
# Example: 0x1234567890123456789012345678901234567890
GOVERNANCE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ERC-20 Token Contract Address (company share token)
# Example: 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48 (USDC on mainnet)
TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# Network Configuration
# Options: mainnet, polygon, sepolia, ganache, etc.
BLOCKCHAIN_NETWORK=sepolia
CHAIN_ID=11155111

# Gas Settings (in wei)
GAS_PRICE_ESTIMATE=20000000000  # 20 Gwei
GAS_LIMIT_VOTING=200000
GAS_LIMIT_VETO=150000

# ============================================================================
# CELERY & ASYNC TASKS
# ============================================================================

# Redis Broker & Result Backend
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# OR for production with authentication
# CELERY_BROKER_URL=redis://:password@hostname:port/0

# Celery Worker Settings
CELERY_CONCURRENCY=4
CELERY_PREFETCH_MULTIPLIER=4
CELERYD_LOG_LEVEL=info

# ============================================================================
# VOTING PARAMETERS
# ============================================================================

# Minimum token percentage to participate (default 5%)
MIN_HOLDER_PERCENTAGE=5

# Quorum percentage (default 16%)
QUORUM_PERCENTAGE=16

# Max vetoes per calendar year by owner (default 2)
MAX_VETOES_PER_YEAR=2

# Veto window in days after voting ends (default 7)
VETO_WINDOW_DAYS=7

# Proposal phase durations (in days)
DISCUSSION_PERIOD_DAYS=3
VOTING_PERIOD_DAYS=7
EXTENSION_PERIOD_DAYS=3
MAX_EXTENSIONS=2

# ============================================================================
# EMAIL & NOTIFICATIONS
# ============================================================================

# Email Backend
# Options: console, smtp, sendgrid, mailgun, amazon_ses
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP Configuration (if using SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
DEFAULT_FROM_EMAIL=notifications@company.com

# SendGrid (alternative)
# SENDGRID_API_KEY=SG.your-api-key-here
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=SG.your-api-key-here

# Notification Recipients
ADMIN_EMAIL=admin@company.com
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_WEBHOOK_URL=https://api.example.com/webhooks/notifications

# ============================================================================
# DATABASE
# ============================================================================

# SQLite (Development - Default)
DATABASE_URL=sqlite:///db.sqlite3

# PostgreSQL (Production)
# DATABASE_URL=postgresql://user:password@localhost:5432/governance_db

# ============================================================================
# DJANGO SETTINGS
# ============================================================================

# Secret Key (Django)
SECRET_KEY=your-super-secret-key-here-change-in-production

# Debug Mode (disable in production!)
DEBUG=True

# Allowed Hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# CORS Settings
CORS_ALLOW_ALL_ORIGINS=True
# For production:
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================

# JWT Secret (use Django SECRET_KEY if not specified)
JWT_SECRET_KEY=your-jwt-secret-key

# JWT Expiration Times
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=500
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ============================================================================
# LOGGING
# ============================================================================

# Log Level
LOG_LEVEL=INFO

# Log File Paths
LOG_FILE_DISCUSSION=logs/discussion.log
LOG_FILE_BLOCKCHAIN=logs/blockchain.log
LOG_FILE_CELERY=logs/celery.log

# ============================================================================
# AWS S3 (for document storage, optional)
# ============================================================================

# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1

# ============================================================================
# MONITORING & SENTRY (optional)
# ============================================================================

# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================================================
# TESTING
# ============================================================================

# Use a test database
# TEST_DATABASE_URL=sqlite:///test_db.sqlite3

# ============================================================================
# SECURITY
# ============================================================================

# HTTPS/SSL
SECURE_SSL_REDIRECT=False  # Set to True in production
SESSION_COOKIE_SECURE=False  # Set to True in production
CSRF_COOKIE_SECURE=False  # Set to True in production

# HSTS (HTTP Strict Transport Security)
SECURE_HSTS_SECONDS=0  # Set to 31536000 in production
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
